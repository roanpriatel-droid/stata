{%- comment -%}
  STATA — Global Header
  Fixed at top, always visible. Wordmark left, nav center, cart right.
  Mobile: hamburger triggers full-screen overlay.
{%- endcomment -%}

<style>
  .stata-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    background-color: var(--stata-obsidian);
    border-bottom: 1px solid var(--stata-graphite);
    z-index: 100;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 32px;
  }

  /* Push body content down so the fixed header doesn't overlap. */
  .stata-header-spacer {
    display: block;
    height: 80px;
  }

  /* WORDMARK */
  .stata-header__wordmark {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-decoration: none;
    line-height: 1;
  }

  .stata-header__wordmark-text {
    font-family: var(--stata-font-display);
    font-weight: 400;
    font-size: 28px;
    color: var(--stata-bone);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .stata-header__wordmark-mark {
    font-family: var(--stata-font-mono);
    font-size: 9px;
    color: var(--stata-gold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  /* CENTER NAV */
  .stata-header__nav {
    display: flex;
    align-items: center;
    gap: 32px;
    justify-self: center;
  }

  .stata-header__link {
    position: relative;
    font-family: var(--stata-font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--stata-bone);
    text-decoration: none;
    padding: 4px 0;
  }

  .stata-header__link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background-color: var(--stata-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 250ms var(--stata-ease-standard);
  }

  .stata-header__link:hover::after,
  .stata-header__link:focus-visible::after {
    transform: scaleX(1);
  }

  /* RIGHT — CART */
  .stata-header__right {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .stata-header__cart {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--stata-bone);
    background: none;
    border: 0;
    padding: 4px;
    cursor: pointer;
  }

  .stata-header__cart-icon {
    width: 20px;
    height: 20px;
    stroke: var(--stata-bone);
    stroke-width: 1.5;
    fill: none;
  }

  .stata-header__cart-count {
    font-family: var(--stata-font-mono);
    font-size: 11px;
    color: var(--stata-bone);
    letter-spacing: 0.05em;
    min-width: 1ch;
    text-align: left;
  }

  /* MOBILE — HAMBURGER */
  .stata-header__hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: 0;
    padding: 8px;
    cursor: pointer;
  }

  .stata-header__hamburger-icon {
    width: 24px;
    height: 16px;
    stroke: var(--stata-bone);
    stroke-width: 1.5;
    fill: none;
  }

  /* MOBILE OVERLAY */
  .stata-header__overlay {
    position: fixed;
    inset: 0;
    background-color: var(--stata-obsidian);
    z-index: 200;
    transform: translateX(100%);
    transition: transform 300ms var(--stata-ease-standard);
    display: flex;
    flex-direction: column;
    padding: 24px 32px 48px;
    visibility: hidden;
  }

  .stata-header__overlay[data-open="true"] {
    transform: translateX(0);
    visibility: visible;
  }

  .stata-header__overlay-top {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 64px;
  }

  .stata-header__overlay-close {
    background: none;
    border: 0;
    padding: 8px;
    cursor: pointer;
  }

  .stata-header__overlay-close svg {
    width: 24px;
    height: 24px;
    stroke: var(--stata-bone);
    stroke-width: 1.5;
    fill: none;
  }

  .stata-header__overlay-nav {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .stata-header__overlay-link {
    font-family: var(--stata-font-mono);
    font-size: 18px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--stata-bone);
    text-decoration: none;
  }

  /* RESPONSIVE */
  @media screen and (max-width: 1023px) {
    .stata-header {
      height: 64px;
      padding: 0 20px;
      grid-template-columns: 1fr auto 1fr;
    }

    .stata-header-spacer {
      height: 64px;
    }

    .stata-header__nav {
      display: none;
    }

    .stata-header__hamburger {
      display: inline-flex;
      justify-self: end;
    }

    /* On mobile, place hamburger at right and cart immediately to its left */
    .stata-header__right {
      gap: 8px;
    }
  }
</style>

<header class="stata-header" role="banner">
  <a href="{{ routes.root_url }}" class="stata-header__wordmark" aria-label="STATA — Tools for the disciplined">
    <span class="stata-header__wordmark-text">STATA</span>
    {%- if section.settings.show_mark -%}
      <span class="stata-header__wordmark-mark">{{ section.settings.mark_text }}</span>
    {%- endif -%}
  </a>

  <nav class="stata-header__nav" aria-label="Primary">
    <a href="{{ section.settings.link_library }}" class="stata-header__link">Library</a>
    <a href="{{ section.settings.link_stacks }}" class="stata-header__link">Stacks</a>
    <a href="{{ section.settings.link_discipline }}" class="stata-header__link">On Discipline</a>
  </nav>

  <div class="stata-header__right">
    <a href="{{ routes.cart_url }}" class="stata-header__cart" aria-label="Cart">
      <svg class="stata-header__cart-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M4 6h16l-1.5 11a2 2 0 01-2 1.7H7.5a2 2 0 01-2-1.7L4 6z"/>
        <path d="M9 6V4.5a3 3 0 016 0V6"/>
      </svg>
      <span class="stata-header__cart-count">{{ cart.item_count }}</span>
    </a>

    <button type="button" class="stata-header__hamburger" aria-label="Open menu" data-stata-menu-open>
      <svg class="stata-header__hamburger-icon" viewBox="0 0 24 16" aria-hidden="true">
        <line x1="0" y1="1" x2="24" y2="1"/>
        <line x1="0" y1="8" x2="24" y2="8"/>
        <line x1="0" y1="15" x2="24" y2="15"/>
      </svg>
    </button>
  </div>
</header>

<div class="stata-header-spacer" aria-hidden="true"></div>

<div class="stata-header__overlay" data-stata-menu-overlay aria-hidden="true">
  <div class="stata-header__overlay-top">
    <button type="button" class="stata-header__overlay-close" aria-label="Close menu" data-stata-menu-close>
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <line x1="3" y1="3" x2="21" y2="21"/>
        <line x1="21" y1="3" x2="3" y2="21"/>
      </svg>
    </button>
  </div>
  <nav class="stata-header__overlay-nav" aria-label="Mobile">
    <a href="{{ section.settings.link_library }}" class="stata-header__overlay-link">Library</a>
    <a href="{{ section.settings.link_stacks }}" class="stata-header__overlay-link">Stacks</a>
    <a href="{{ section.settings.link_discipline }}" class="stata-header__overlay-link">On Discipline</a>
    <a href="{{ routes.cart_url }}" class="stata-header__overlay-link">Cart ({{ cart.item_count }})</a>
  </nav>
</div>

<script>
  (function () {
    var overlay = document.querySelector('[data-stata-menu-overlay]');
    var openBtn = document.querySelector('[data-stata-menu-open]');
    var closeBtn = document.querySelector('[data-stata-menu-close]');
    if (!overlay || !openBtn || !closeBtn) return;

    function setOpen(isOpen) {
      overlay.setAttribute('data-open', isOpen ? 'true' : 'false');
      overlay.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      document.documentElement.style.overflow = isOpen ? 'hidden' : '';
    }

    openBtn.addEventListener('click', function () { setOpen(true); });
    closeBtn.addEventListener('click', function () { setOpen(false); });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.getAttribute('data-open') === 'true') setOpen(false);
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_mark",
      "label": "Show MMXXVI superscript",
      "default": true
    },
    {
      "type": "text",
      "id": "mark_text",
      "label": "Superscript text",
      "default": "MMXXVI"
    },
    {
      "type": "url",
      "id": "link_library",
      "label": "Library link",
      "default": "/collections/all"
    },
    {
      "type": "url",
      "id": "link_stacks",
      "label": "Stacks link",
      "default": "/collections/stacks"
    },
    {
      "type": "url",
      "id": "link_discipline",
      "label": "On Discipline link",
      "default": "/pages/on-discipline"
    }
  ]
}
{% endschema %}
