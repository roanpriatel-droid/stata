{%- comment -%}
  STATA — Library
  Sticky label left, 3-col product grid right. 10 products hardcoded.
  Stagger fade-in per card via IntersectionObserver.
{%- endcomment -%}

<style>
  .stata-library-section {
    background-color: var(--stata-obsidian);
    padding: 160px 32px;
  }

  .stata-library-section__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 30% 70%;
    gap: 80px;
    align-items: start;
  }

  .stata-library-section__label {
    position: sticky;
    top: 160px;
  }

  .stata-library-section__eyebrow {
    font-family: var(--stata-font-mono);
    font-size: 11px;
    color: var(--stata-gold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 32px 0;
  }

  .stata-library-section__heading {
    font-family: var(--stata-font-display);
    font-weight: 400;
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--stata-bone);
    margin: 0 0 24px 0;
  }

  .stata-library-section__intro {
    font-family: var(--stata-font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--stata-warm-white);
    max-width: 320px;
    margin: 0;
  }

  .stata-library-section__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 32px;
    row-gap: 48px;
  }

  .stata-library-section__card {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 400ms var(--stata-ease-luxurious),
      transform 400ms var(--stata-ease-luxurious);
  }

  .stata-library-section__card.is-in {
    opacity: 1;
    transform: translateY(0);
  }

  .stata-library-section__image-wrap {
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background-color: var(--stata-charcoal);
  }

  .stata-library-section__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--stata-ease-standard);
    will-change: transform;
  }

  .stata-library-section__card:hover .stata-library-section__image {
    transform: scale(1.02);
  }

  .stata-library-section__num {
    font-family: var(--stata-font-mono);
    font-size: 11px;
    color: var(--stata-gold);
    letter-spacing: 0.15em;
    margin: 12px 0 0 0;
    transition: color 200ms var(--stata-ease-standard);
  }

  .stata-library-section__card:hover .stata-library-section__num {
    color: var(--stata-oxblood);
  }

  .stata-library-section__name {
    position: relative;
    display: inline-block;
    font-family: var(--stata-font-display);
    font-weight: 400;
    font-size: 22px;
    letter-spacing: -0.01em;
    color: var(--stata-bone);
    margin: 8px 0 0 0;
  }

  .stata-library-section__name::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background-color: var(--stata-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 250ms var(--stata-ease-standard);
  }

  .stata-library-section__card:hover .stata-library-section__name::after {
    transform: scaleX(1);
  }

  .stata-library-section__price {
    font-family: var(--stata-font-mono);
    font-size: 13px;
    color: var(--stata-warm-white);
    margin: 8px 0 0 0;
  }

  @media screen and (max-width: 1023px) {
    .stata-library-section { padding: 100px 20px; }
    .stata-library-section__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .stata-library-section__label { position: static; }
    .stata-library-section__heading { font-size: 36px; }
    .stata-library-section__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media screen and (max-width: 767px) {
    .stata-library-section__grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .stata-library-section__card {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

{%- assign products = 'The STATA Dashboard|the-stata-dashboard|$67;The Operator’s Planner|the-operators-planner|$37;The STATA Calendar|the-stata-calendar|$28;The Habit Ledger|the-habit-ledger|$32;The Reading Ledger|the-reading-ledger|$27;The Capital Sheet|the-capital-sheet|$47;The Goals Brief|the-goals-brief|$32;The Journal|the-journal|$24;The Network|the-network|$37;The Project Brief|the-project-brief|$34' | split: ';' -%}

<section class="stata-library-section" data-stata-library>
  <div class="stata-library-section__inner">
    <div class="stata-library-section__label">
      <p class="stata-library-section__eyebrow">{{ section.settings.eyebrow | default: 'THE LIBRARY  ·  010 INSTRUMENTS' }}</p>
      <h2 class="stata-library-section__heading">{{ section.settings.heading | default: 'Ten instruments. Numbered.' }}</h2>
      <p class="stata-library-section__intro">{{ section.settings.intro | default: 'Each instrument is sold separately or as part of an engineered stack.' }}</p>
    </div>

    <div class="stata-library-section__grid">
      {%- for entry in products -%}
        {%- assign parts = entry | split: '|' -%}
        {%- assign name = parts[0] -%}
        {%- assign handle = parts[1] -%}
        {%- assign price = parts[2] -%}
        {%- assign idx = forloop.index -%}
        {%- assign num = idx | prepend: '00' | slice: -3, 3 -%}
        <a href="/products/{{ handle }}" class="stata-library-section__card" data-stata-library-card>
          <div class="stata-library-section__image-wrap">
            <img
              src="{{ 'stata-product-placeholder.svg' | asset_url }}"
              alt="{{ name }}"
              class="stata-library-section__image"
              loading="lazy"
              width="800"
              height="1000"
            >
          </div>
          <p class="stata-library-section__num">{{ num }}</p>
          <h3 class="stata-library-section__name">{{ name }}</h3>
          <p class="stata-library-section__price">{{ price }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var cards = document.querySelectorAll('[data-stata-library-card]');
    if (!cards.length) return;
    if (!('IntersectionObserver' in window)) {
      cards.forEach(function (c) { c.classList.add('is-in'); });
      return;
    }
    var seen = 0;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var delay = (seen % 3) * 50;
          seen++;
          setTimeout(function () { entry.target.classList.add('is-in'); }, delay);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    cards.forEach(function (c) { io.observe(c); });
  })();
</script>

{% schema %}
{
  "name": "STATA Library",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "THE LIBRARY  ·  010 INSTRUMENTS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ten instruments. Numbered." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Each instrument is sold separately or as part of an engineered stack." }
  ],
  "presets": [{ "name": "STATA Library" }]
}
{% endschema %}
