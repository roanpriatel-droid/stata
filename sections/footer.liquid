{%- comment -%}
  STATA — Global Footer
  3-column on true-black with hairline gold top border. Wordmark, two link cols.
  Bottom bar: copyright, two social icons (X, Instagram).
{%- endcomment -%}

<style>
  .stata-footer {
    background-color: var(--stata-true-black);
    padding: 80px 32px 40px;
    border-top: 1px solid var(--stata-gold);
    color: var(--stata-bone);
  }

  .stata-footer__inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .stata-footer__cols {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 64px;
  }

  /* COL 1 — BRAND */
  .stata-footer__brand-wordmark {
    font-family: var(--stata-font-display);
    font-weight: 400;
    font-size: 36px;
    color: var(--stata-bone);
    letter-spacing: -0.01em;
    line-height: 1;
    margin: 0;
  }

  .stata-footer__brand-tag {
    font-family: var(--stata-font-mono);
    font-size: 11px;
    color: var(--stata-stone);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 16px 0 0 0;
  }

  .stata-footer__monogram {
    margin-top: 32px;
    width: 32px;
    height: 32px;
    display: block;
  }

  /* COLS 2 + 3 — LINKS */
  .stata-footer__col-head {
    font-family: var(--stata-font-mono);
    font-size: 11px;
    color: var(--stata-gold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 24px 0;
  }

  .stata-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .stata-footer__link {
    font-family: var(--stata-font-body);
    font-size: 14px;
    color: var(--stata-bone);
    text-decoration: none;
    transition: color 200ms var(--stata-ease-standard);
  }

  .stata-footer__link:hover,
  .stata-footer__link:focus-visible {
    color: var(--stata-gold);
  }

  /* BOTTOM BAR */
  .stata-footer__bar {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--stata-graphite);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .stata-footer__bar-left {
    font-family: var(--stata-font-mono);
    font-size: 11px;
    color: var(--stata-stone);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .stata-footer__bar-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .stata-footer__social {
    display: inline-flex;
    color: var(--stata-stone);
    transition: color 200ms var(--stata-ease-standard);
  }

  .stata-footer__social svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
  }

  .stata-footer__social:hover,
  .stata-footer__social:focus-visible {
    color: var(--stata-gold);
  }

  .stata-footer__rights {
    font-family: var(--stata-font-mono);
    font-size: 11px;
    color: var(--stata-stone);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  @media screen and (max-width: 1023px) {
    .stata-footer { padding: 64px 20px 32px; }
    .stata-footer__cols {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .stata-footer__bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      margin-top: 48px;
    }
  }
</style>

<footer class="stata-footer" role="contentinfo">
  <div class="stata-footer__inner">
    <div class="stata-footer__cols">
      <div>
        <p class="stata-footer__brand-wordmark">STATA</p>
        <p class="stata-footer__brand-tag">{{ section.settings.tagline | default: 'TOOLS FOR THE DISCIPLINED' }}</p>
        <svg class="stata-footer__monogram" viewBox="0 0 32 32" aria-hidden="true">
          <path d="M3 8 H14 M3 8 V14 M3 14 H14 M14 14 V20 M3 20 H14 M14 26 H22" stroke="#B8945F" stroke-width="1" fill="none" stroke-linecap="square"/>
          <path d="M22 6 V26 M16 6 H28" stroke="#B8945F" stroke-width="1" fill="none" stroke-linecap="square"/>
        </svg>
      </div>

      <div>
        <p class="stata-footer__col-head">Library</p>
        <ul class="stata-footer__links">
          <li><a href="{{ section.settings.link_library | default: '/collections/all' }}" class="stata-footer__link">The Library</a></li>
          <li><a href="{{ section.settings.link_stacks | default: '/collections/stacks' }}" class="stata-footer__link">The Stacks</a></li>
          <li><a href="{{ section.settings.link_discipline | default: '/pages/on-discipline' }}" class="stata-footer__link">On Discipline</a></li>
          <li><a href="{{ section.settings.link_coming_soon | default: '/pages/coming-soon' }}" class="stata-footer__link">Coming Soon</a></li>
        </ul>
      </div>

      <div>
        <p class="stata-footer__col-head">Elsewhere</p>
        <ul class="stata-footer__links">
          <li><a href="{{ section.settings.link_contact | default: '/pages/contact' }}" class="stata-footer__link">Contact</a></li>
          <li><a href="{{ section.settings.link_refunds | default: '/policies/refund-policy' }}" class="stata-footer__link">Refunds</a></li>
          <li><a href="{{ section.settings.link_terms | default: '/policies/terms-of-service' }}" class="stata-footer__link">Terms</a></li>
          <li><a href="{{ section.settings.link_privacy | default: '/policies/privacy-policy' }}" class="stata-footer__link">Privacy</a></li>
        </ul>
      </div>
    </div>

    <div class="stata-footer__bar">
      <p class="stata-footer__bar-left">STATA — MMXXVI</p>
      <div class="stata-footer__bar-right">
        <a href="{{ section.settings.link_twitter | default: 'https://x.com' }}" class="stata-footer__social" aria-label="STATA on X">
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <line x1="2" y1="2" x2="14" y2="14"/>
            <line x1="14" y1="2" x2="2" y2="14"/>
          </svg>
        </a>
        <a href="{{ section.settings.link_instagram | default: 'https://instagram.com' }}" class="stata-footer__social" aria-label="STATA on Instagram">
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <rect x="2" y="2" width="12" height="12" rx="0"/>
            <circle cx="8" cy="8" r="3"/>
            <circle cx="12" cy="4" r="0.5" fill="currentColor"/>
          </svg>
        </a>
        <p class="stata-footer__rights">© All Rights Reserved</p>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "TOOLS FOR THE DISCIPLINED" },
    { "type": "header", "content": "Library column" },
    { "type": "url", "id": "link_library", "label": "The Library link", "default": "/collections/all" },
    { "type": "url", "id": "link_stacks", "label": "The Stacks link", "default": "/collections/stacks" },
    { "type": "url", "id": "link_discipline", "label": "On Discipline link", "default": "/pages/on-discipline" },
    { "type": "url", "id": "link_coming_soon", "label": "Coming Soon link", "default": "/pages/coming-soon" },
    { "type": "header", "content": "Elsewhere column" },
    { "type": "url", "id": "link_contact", "label": "Contact link", "default": "/pages/contact" },
    { "type": "url", "id": "link_refunds", "label": "Refunds link", "default": "/policies/refund-policy" },
    { "type": "url", "id": "link_terms", "label": "Terms link", "default": "/policies/terms-of-service" },
    { "type": "url", "id": "link_privacy", "label": "Privacy link", "default": "/policies/privacy-policy" },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "link_twitter", "label": "X / Twitter URL", "default": "https://x.com" },
    { "type": "url", "id": "link_instagram", "label": "Instagram URL", "default": "https://instagram.com" }
  ]
}
{% endschema %}
